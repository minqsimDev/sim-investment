# deploy/.env  — 실제 값으로 복사해 EC2 호스트에만 둔다. 절대 깃·이미지에 넣지 말 것.
#   cp .env.example .env  &&  chmod 600 .env
# (compose가 ${DOMAIN} 치환 + app 컨테이너에 시크릿 주입)

# Caddy 자동 HTTPS 대상 도메인 (Route53 A레코드가 EC2 Elastic IP를 가리켜야 함)
DOMAIN=invest.example.com

# ── 앱 시크릿 ───────────────────────────────────────────────
FRED_API_KEY=
FMP_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
# 토스: 발급 키. EC2 Elastic IP를 토스 콘솔 허용목록에 등록해야 동작.
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
# 시세 소스 라우팅. 미설정(기본)=yfinance 단일 — 데이터센터 IP에선 yfinance가 레이트리밋/차단될 수 있다.
# AWS 고정 Elastic IP를 토스 허용목록에 등록했다면 1 로 켜서 국내·미국 주식/ETF·USD-KRW 를
# 토스로 라우팅(나머지는 yfinance 폴백). 권장: AWS=1.
USE_TOSS=1
