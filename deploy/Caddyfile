# 도메인 트래픽 → 앱(8520). HTTPS 인증서는 Caddy가 Let's Encrypt로 자동 발급·갱신. 웹소켓 자동 통과.
#
# ⚠️ _stcore 리라이트 금지: `^/<page>/(_stcore/.*) → /_stcore/$1` 리라이트를 넣으면
#    상대 _stcore/host-config 가 200이 돼 프런트엔드가 baseUrlPath 를 '/<page>'로 오인 →
#    멀티페이지 딥링크/하드네비가 항상 홈으로 라우팅된다(로컬 프록시로 재현·확인).
#    리라이트 없이 두면 프런트엔드가 _stcore 를 루트로 폴백해 정상 라우팅된다(콘솔 404는 무해).
{$DOMAIN} {
	encode zstd gzip
	reverse_proxy app:8520
}
